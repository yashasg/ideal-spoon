{
  "base_model": "Qwen/Qwen2.5-0.5B",
  "tokenizer_name": null,
  "unicode_normalization": "NFC",

  "train_path": "../examples/stage2_sft.jsonl.example",
  "eval_path": null,
  "text_field": "text",
