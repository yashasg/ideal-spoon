  "seed": 7,

  "output_dir": "runs/stage2-smoke",
  "logging_steps": 1,
  "save_steps": 50,
  "eval_steps": null,
  "save_total_limit": 1,

  "stage": "stage2-sft",
  "run_name": "qwen25-0.5b-stage2-smoke",
  "parent_run_dir": null,
  "notes": {
    "purpose": "Stage 2 SFT smoke test. 3 example rows; no GPU required. Verify target-only masking and SFT data path before committing GPU time.",
    "path_note": "train_path is config-relative. Run from repo root: PYTHONPATH=code python -m llm_hawaii.train --config code/configs/stage2_smoke.json --preflight"
  }
